    "settings.delete.rejected": {"extractionState":"manual","localizations":{"en":{"stringUnit":{"state":"translated","value":"Nothing was deleted. Rocio could not safely save the deletion request; retry after cloud sync recovers."}},"es":{"stringUnit":{"state":"translated","value":"No se eliminó nada. Rocio no pudo guardar de forma segura la solicitud de eliminación; inténtalo de nuevo cuando se recupere la sincronización."}}}},
