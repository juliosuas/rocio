    "scanner.disclaimer": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plant identification is probabilistic. Cloud results use Plant.id when available; Rocio falls back to a simple on-device flower match. Always verify before acting."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La identificación de plantas es probabilística. Rocio usa Plant.id cuando está disponible y recurre a una coincidencia local de flores si falla. Verifica siempre antes de actuar."
          }
        }
      }
    },
